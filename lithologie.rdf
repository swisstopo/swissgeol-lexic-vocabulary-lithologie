	<skos:prefLabel xml:lang="it">Hettangiano</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyJurassic"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Hettangian"/>
