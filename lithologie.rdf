	<skos:prefLabel xml:lang="it">Carixiano</skos:prefLabel>
	<skos:altLabel xml:lang="en">early Pliensbachian</skos:altLabel>
	<skos:altLabel xml:lang="de">frühes Pliensbachien</skos:altLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pliensbachian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/sub-stage"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Domerian"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pliensbachian"/>
</rdf:Description>

