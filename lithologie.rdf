	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mesozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Triassic">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Triassic (approx. from 252 to 201 Ma ago) is the oldest geochronologic period of the Mesozoic, starting with the Induan age (at the transition from the Permian period) and ending with the Rhaetian age (at the transition to the Jurassic period). It is subdivided into three epochs (Early, Middle and Late Triassic).
Tectonically it is a rather quiet period inbetween the Variscan and Alpine orogenic cycles. The first deposits are transgressive on a vast peneplain.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Triassic</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Trias</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Trias</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Triassico</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mesozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Werfenian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Scythian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyTriassic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateTriassic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleTriassic"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Triassic"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateTriassic"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Permian"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyTriassic"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Jurassic"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mesozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Jurassic">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Jurassic (approx. from 201 to 145 Ma ago) is the middle geochronologic period of the Mesozoic, starting with the Hettangian age (at the transition from the Triassic period) and ending with the Tithonian age (at the transition to the Cretaceous period). It is subdivided into three epochs (Early, Middle and Late Jurassic).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Jurassic</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Jura</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Jurassique</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Giurassico</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mesozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyJurassic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateJurassic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleJurassic"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Jurassic"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateJurassic"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Triassic"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyJurassic"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Precambrian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Precambrian (approx. from 4657 to 539 Ma ago) is an informal geochronologic unit grouping the Hadean, Archean and Proterozoic eons.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:topConceptOf rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Precambrian</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Präkambrium</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Précambrien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Precambriano</skos:prefLabel>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Proterozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Archean"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Hadean"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Precambrian"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Proterozoic"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Hadean"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/super-eon"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Archean">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Archean (approx. 4031 to 2500 Ma ago) is the middle geochronologic eon of the Precambrian (between the Hadean and the Proterozoic). It is subdivided into four eras (Eo-, Paleo-, Meso- and Neoarchean).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Archean</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Archaikum</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Archéen</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Archeano</skos:prefLabel>
	<skos:altLabel xml:lang="en">Archeozoic</skos:altLabel>
	<skos:altLabel xml:lang="de">Urzeit</skos:altLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Precambrian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Archean"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Hadean"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/eon"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Proterozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Hadean">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Hadean (approx. from 4567 to 4031 Ma ago) is the oldest geochronologic eon of the Precambrian (before the Archean) and goes back to the origin of the Earth.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Hadean</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Hadaikum</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Hadéen</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Adeano</skos:prefLabel>
	<skos:altLabel xml:lang="en">Pre-Archean</skos:altLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Precambrian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Hadean"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/eon"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Archean"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Precambrian"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Silurian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Silurian (approx. from 444 to 419 Ma ago) is the youngest geochronologic period of the early Paleozoic, starting with the Rhuddanian age (at the transition from the Ordovician period) and ending with the Pridoli Epoch (at the transition to the Devonian period). It is subdivided into four epochs (Llandovery, Wenlock, Ludlow and Pridoli).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Silurian</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Silur</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Silurien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Siluriano</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPaleozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pridoli"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Llandovery"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Ludlow"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Wenlock"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Silurian"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pridoli"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Ordovician"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Llandovery"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Devonian"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPaleozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Ordovician">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Ordovician (approx. from 485 to 444 Ma ago) is the middle geochronologic period of the early Paleozoic, starting with the Tremadocian age (at the transition from the Cambrian period) and ending with the Hirnantian age (at the transition to the Silurian period). It is subdivided into three epochs (Early, Middle and Late Ordovician).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Ordovician</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Ordovizium</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Ordovicien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Ordoviciano</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPaleozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyOrdovician"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateOrdovician"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleOrdovician"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Ordovician"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateOrdovician"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cambrian"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyOrdovician"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Silurian"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cambrian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Cambrian (approx. from 539 to 485 Ma ago) is the oldest geochronologic period of the early Paleozoic, starting with the Fortunian age (at the transition from the Proterozoic eon) and ending with an unnamed age of the Furongian epoch (at the transition to the Ordovician period). It is subdivided into four epochs (Terreneuvian, "Series 2", Miaolingian and Furongian).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Cambrian</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Kambrium</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Cambrien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Cambriano</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPaleozoic"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Cambrian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Ordovician"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPaleozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Permian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Permian (approx. from 299 to 252 Ma ago) is the youngest geochronologic period of the late Paleozoic, starting with the Asselian age (at the transition from the Carboniferous period) and ending with the Changhsingian age (at the transition to the Triassic period). It is subdivided into three epochs (Cisuralian, Guadalupian and Lopingian).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Permian</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Perm</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Permien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Permiano</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePaleozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Lopingian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cisuralian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Guadalupian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Thuringian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Saxonian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Autunian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Permian"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Lopingian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Carboniferous"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cisuralian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Triassic"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePaleozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Carboniferous">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Carboniferous (approx. 359 to 299 Ma ago) is the oldest geochronologic period of the late Paleozoic, starting with the Tournaisian age (at the transition from the Devonian period) and ending with the Gzhelian age (at the transition to the Permian period). It is subdivided into two epochs (Mississippian and Pennsylvanian).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Carboniferous</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Karbon</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Carbonifère</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Carbonifero</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePaleozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pennsylvanian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mississippian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Silesian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Dinantian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Carboniferous"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pennsylvanian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Devonian"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mississippian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Permian"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Devonian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Devonian (approx. from 419 to 359 Ma ago) is a geochronologic period of the Paleozoic, starting with the Lochkovian age (at the transition from the Silurian period) and ending with the Famennian age (at the transition to the Pernian period). It is subdivided into three epochs (Early, Middle and Late Devonian).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Devonian</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Devon</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Dévonien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Devoniano</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePaleozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyDevonian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateDevonian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleDevonian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Devonian"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateDevonian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Silurian"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyDevonian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Carboniferous"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePaleozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Oligocene">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Oligocene (approx. from 34 to 23 Ma ago) is the youngest geochronologic epoch of the Paleogene, starting with the Rupelian age (at the transition from the Eocene epoch) and ending with the Chattian age (at the transition to the Miocene epoch).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Oligocene</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Oligozän</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Oligocène</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Oligocene</skos:prefLabel>
	<skos:hiddenLabel>Oligocaen</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Chattian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Rupelian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Stampian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Sannoisian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Oligocene"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Chattian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Eocene"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Rupelian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/epoch"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Miocene"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleocene">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Paleocene (approx. from 66 to 56 Ma ago) is the oldest geochronologic epoch of the Paleogene, starting with the Danian age (at the transition from the Late Cretaceous epoch) and ending with the Thanttian age (at the transition to the Eocene epoch). It is subdivided into three ages (Danian, Selandian and Thanetian).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Paleocene</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Paleozän</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Paléocène</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Paleocene</skos:prefLabel>
	<skos:hiddenLabel>Palaeocaen</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Thanetian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Danian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Selandian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Paleocene"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Thanetian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateCretaceous"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Danian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/epoch"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Eocene"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Eocene">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Eocene (approx. from 56 to 34 Ma ago) is the middle geochronologic epoch of the Paleogene, starting with the Ypresian age (at the transition from the Paleocene epoch) and ending with the Priabonian age (at the transition to the Oligocene epoch). It is subdivided into four ages (Ypresian, Lutetian, Bartonian and Priabonian).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Eocene</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Eozän</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Eocène</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Eocene</skos:prefLabel>
	<skos:hiddenLabel>Eocaen</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Tongrian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Auversian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyEocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateEocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleEocene"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Eocene"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateEocene"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleocene"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyEocene"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/epoch"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Oligocene"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pleistocene">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Pleistocene (approx. from 2,5 Ma to 12 ka ago) is the oldest geochronologic epoch of the Quaternary, starting with the Gelasian age (at the transition from the Pliocene epoch) and ending with an unnamed age at the transition to the Holocene epoch. It is subdivided into three subepochs (Early, Middle and Late Pleistocene).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Pleistocene</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Pleistozän</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Pléistocène</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Pleistocene</skos:prefLabel>
	<skos:altLabel xml:lang="de">Eiszeitalter</skos:altLabel>
	<skos:hiddenLabel>Pleistocaen</skos:hiddenLabel>
	<skos:hiddenLabel xml:lang="de">Diluvium</skos:hiddenLabel>
	<skos:changeNote xml:lang="en">base moved back in 2009 to encompass the Gelasian</skos:changeNote>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Quaternary"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPleistocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePleistocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddlePleistocene"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Pleistocene"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePleistocene"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pliocene"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPleistocene"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/epoch"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Holocene"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Quaternary"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Holocene">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Holocene is the most recent geochronologic epoch of the Quaternary, referring to the warm episod that began with the end of the last glacial period.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Holocene</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Holozän</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Holocène</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Olocene</skos:prefLabel>
	<skos:altLabel xml:lang="de">Jungquartär</skos:altLabel>
	<skos:altLabel xml:lang="de">Nacheiszeit</skos:altLabel>
	<skos:hiddenLabel>Holocaen</skos:hiddenLabel>
	<skos:hiddenLabel xml:lang="de">Alluvium</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Quaternary"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Holocene"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pleistocene"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/epoch"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Quaternary"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pliocene">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Pliocene (approx. from 5 to 2.6 Ma ago) is the last geochronologic epoch of the Neogene, starting with the Zanclean age (at the transition from the Miocene epoch) and ending with the Piacenzian age (at the transition to the Pleistocene epoch).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Pliocene</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Pliozän</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Pliocène</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Pliocene</skos:prefLabel>
	<skos:hiddenLabel>Pliocaen</skos:hiddenLabel>
	<skos:historyNote xml:lang="en">previously part of Quaternary</skos:historyNote>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neogene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Piacenzian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Zanclean"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Pliocene"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Piacenzian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Miocene"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Zanclean"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/epoch"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pleistocene"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neogene"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Miocene">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Miocene (approx. from 23 to 5 Ma ago) is the oldest geochronologic epoch of the Neogene, starting with the Aquitanian age (at the transition from the Oligocene epoch) and ending with the Messinian age (at the transition to the Pliocene epoch).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Miocene</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Miozän</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Miocène</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Miocene</skos:prefLabel>
	<skos:hiddenLabel>Miocaen</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neogene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Vindobonian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyMiocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateMiocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleMiocene"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Miocene"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateMiocene"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Oligocene"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyMiocene"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/epoch"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pliocene"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neogene"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Werfenian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Werfenian</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Werfenien</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Werfénien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Werfeniano</skos:prefLabel>
	<skos:altLabel xml:lang="de">Werfen</skos:altLabel>
	<skos:historyNote xml:lang="en">historical concept, no longer in use</skos:historyNote>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Triassic"/>
	<skos:related rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyTriassic"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/historic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Scythian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Scythian</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Scythien</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Scythien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Scitiano</skos:prefLabel>
	<skos:altLabel xml:lang="de">Skyth</skos:altLabel>
	<skos:historyNote xml:lang="en">historical concept, no longer in use</skos:historyNote>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Triassic"/>
	<skos:related rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyTriassic"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/historic"/>
