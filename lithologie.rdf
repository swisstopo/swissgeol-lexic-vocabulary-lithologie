<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Carixian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Carixian is a geochronologic subdivision of the Early Jurassic corresponding informally to the early Pliensbachian.</skos:definition>
