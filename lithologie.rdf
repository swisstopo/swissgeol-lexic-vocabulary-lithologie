<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyCretaceous">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Early Cretaceous (approx. from 145 to 100 Ma ago) is the oldest geochronologic subepoch of the Cretaceous, starting with the Berriasian age (at the transition from the Late Jurassic subepoch) and ending with the Albian age (at the transition to the Late Cretaceous subepoch). It is subdivided into six ages (Berriasian, Valanginian, Hauterivian, Barremian, Aptian and Albian).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Early Cretaceous</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Frühe Kreide</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Crétacé précoce</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Primo Cretacico</skos:prefLabel>
	<skos:altLabel xml:lang="it">Primo Cretaceo</skos:altLabel>
	<skos:altLabel xml:lang="de">Frühkreide</skos:altLabel>
	<skos:hiddenLabel>Unterkreide</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Albian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Aptian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Berriasian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Valanginian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Barremian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Hauterivian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neocomian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/LowerCretaceous"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Albian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateJurassic"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Berriasian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/epoch"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateCretaceous"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateCretaceous">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Late Cretaceous (approx. from 100 to 66 Ma ago) is the youngest geochronologic subepoch of the Cretaceous, starting with the Cenomanian age (at the transition from the Early Cretaceous subepoch) and ending with the Maastrichtian age (at the transition to the Plaeocene subepoch). It is subdivided into six ages (Cenomanian, Turonian, Coniacian, Santonian, Campanian and Maastrichtian).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Late Cretaceous</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Späte Kreide</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Crétacé tardif</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Tardo Cretacico</skos:prefLabel>
	<skos:altLabel xml:lang="it">Tardo Cretaceo</skos:altLabel>
	<skos:altLabel xml:lang="de">Spätkreide</skos:altLabel>
	<skos:hiddenLabel>Oberkreide</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Maastrichtian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Campanian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenomanian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Turonian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Santonian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Coniacian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Senonian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/UpperCretaceous"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Maastrichtian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyCretaceous"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenomanian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/epoch"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleocene"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleCretaceous">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
	<skos:definition xml:lang="en">The «middle Cretaceous» is an obsolete geochronologic subdivision of the Cretaceous period.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">middle Cretaceous</skos:prefLabel>
	<skos:prefLabel xml:lang="de">mittlere Kreide</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Crétacé moyen</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Cretacico medio</skos:prefLabel>
	<skos:historyNote xml:lang="en">historical concept, no longer in use</skos:historyNote>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/historic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPaleozoic">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The early Paleozoic (approx. from 539 to 419 Ma ago) is an informal subdivision of the Paleozoic geochronologic era encompassing the Cambrian, Ordovician and Silurian periods.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">early Paleozoic</skos:prefLabel>
	<skos:prefLabel xml:lang="de">frühes Paläozoikum</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Paléozoïque précoce</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Primo Paleozoico</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Silurian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Ordovician"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cambrian"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Silurian"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cambrian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/sub-era"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePaleozoic"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePaleozoic">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The late Paleozoic (approx. from 359 to 252 Ma ago) is an informal subdivision of the Paleozoic geochronologic era encompassing the Carboniferous and Permian periods,</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">late Paleozoic</skos:prefLabel>
	<skos:prefLabel xml:lang="de">spätes Paläozoikum</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Paléozoïque tardif</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Tardo Paleozoico</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Permian"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Carboniferous"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Devonian"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Permian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPaleozoic"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Devonian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/sub-era"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyDevonian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
