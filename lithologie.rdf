<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Aalenian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Aalenian (approx. from 174 to 170 Ma ago) is the oldest geochronologic age of the Middle Jurassic. Its base, at the transition from the Toarcian, is placed at the first appearance of the ammonite genus Leioceras, and the base of the Bajocian defines its end.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Aalenian</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Aalénien</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Aalénien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Aaleniano</skos:prefLabel>
	<skos:historyNote xml:lang="en">previously part of Early Jurassic</skos:historyNote>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleJurassic"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Aalenian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Toarcian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/stage"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Bajocian"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleJurassic"/>
</rdf:Description>

