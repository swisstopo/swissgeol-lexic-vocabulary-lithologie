</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Phanerozoic">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Phanerozoic (approx. from 539 Ma ago to the Present) is the main (though not the longest) eon of Earth history, encompassing the Paleozoic, Mesozoic and Cenonoic eras.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:topConceptOf rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Phanerozoic</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Phanerozoikum</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Phanérozoïque</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Fanerozoico</skos:prefLabel>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mesozoic"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Phanerozoic"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Proterozoic"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleozoic"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/eon"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
	<skos:prefLabel xml:lang="en">Chronostratigraphy</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Chronostratigraphie</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Cronostratigrafia</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Chronostratigraphie</skos:prefLabel>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleozoic">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Paleozoic (approx. from 539 to 252 Ma ago) is the oldest geochronologic era of the Phanerozoic eon, starting with the Fortunian age (at the transition from the Proterozoic eon) and ending with the Changhsingian age (at the transition to the Mesozoic period). It is subdivided into six periods (Cambrian, Ordovician, Silurian, Devonian, Carboniferous and Permian).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Paleozoic</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Paläozoikum</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Paléozoïque</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Paleozoico</skos:prefLabel>
	<skos:hiddenLabel xml:lang="en">Primary</skos:hiddenLabel>
	<skos:hiddenLabel xml:lang="de">Primär</skos:hiddenLabel>
	<skos:hiddenLabel xml:lang="fr">Primaire</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Phanerozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPaleozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePaleozoic"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Paleozoic"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LatePaleozoic"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyPaleozoic"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/era"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mesozoic"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Phanerozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Cenozoic (approx. from 66 Ma ago to the Present) is the youngest geochronologic era of the Phanerozoic eon, starting with the Danian age (at the transition from the Mesozoic era) and going into the Present. It is subdivided into three periods (Paleogene, Neogene and Quaternary).</skos:definition>
	<skos:scopeNote xml:lang="en">encompasses both the Quaternary and "Tertiary" (Neogene + Paleogene)</skos:scopeNote>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Cenozoic</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Känozoikum</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Cénozoïque</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Cenozoico</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Phanerozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Quaternary"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neogene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Tertiary"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Cenozoic"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Quaternary"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mesozoic"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/era"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Phanerozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mesozoic">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Mesozoic (approx. from 201 to 66 Ma ago) is the middle geochronologic era of the Phanerozoic eon, starting with the Induan age (at the transition from the Paleozoic era) and ending with the Maastrichtian age (at the transition to the Cenozoic period). It is subdivided into three periods (Triassic, Jurassic and Cretaceous).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Mesozoic</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Mesozoikum</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Mésozoïque</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Mesozoico</skos:prefLabel>
	<skos:hiddenLabel xml:lang="en">Secondary</skos:hiddenLabel>
	<skos:hiddenLabel xml:lang="de">Sekundär</skos:hiddenLabel>
	<skos:hiddenLabel xml:lang="fr">Secondaire</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Phanerozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Triassic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Jurassic"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Mesozoic"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleozoic"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Triassic"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/era"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Proterozoic">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Proterozoic (approx. from 2500 to 539 Ma ago) is the youngest geochronologic eon of the Precambrian, starting with the Siderian period (at the transition from the Archean eon) and ending with the Ediacaran period (at the transition to the Phanerozoic eon). It is subdivided into three eras (Paleo-, Meso- and Neoproterozoic).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Proterozoic</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Proterozoikum</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Protérozoïque</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Proterozoico</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Precambrian"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Proterozoic"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Archean"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/eon"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Phanerozoic"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Precambrian"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Paleogene (approx. from 66 to 23 Ma ago; formal name for the «early Tertiary») is the oldest geochronologic period of the Cenozoic, starting with the Danian age (at the transition from the Cretaceous period) and ending with the Chattian age (at the transition to the Neogene period). It is subdivided into three epochs (Paleocene, Eocene and Oligocene).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Paleogene</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Paläogen</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Paléogène</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Paleogene</skos:prefLabel>
	<skos:hiddenLabel xml:lang="de">Alttertiär</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Oligocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Eocene"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Paleogene"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Oligocene"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleocene"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neogene"/>
	<intervalStarts xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Quaternary">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Quaternary is the youngest geochronologic period of the Cenozoic, starting 2,58 Ma ago with the Gelasian age (at the transition from the Neogene period) and still going on into the Present. It is subdivided into two epochs (Pleistocene and Holocene). The base of the Quaternary is set at the Gauss/Matuyama palaeomagnetic reversal and the period is characterised by successive glacials in a context of increased global ice volume. In Switzerland one can assume that all of the (peri)glacial deposits belong to the Quaternary.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Quaternary</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Quartär</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Quaternaire</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Quaternario</skos:prefLabel>
	<skos:changeNote xml:lang="en">base moved back in 2009 to encompass the Gelasian</skos:changeNote>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pleistocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Holocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleQuaternary"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/OldQuaternary"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Quaternary"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Holocene"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neogene"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pleistocene"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neogene">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Neogene (approx. from 23 to 2,6 Ma; formal name for the «late Tertiary») is the middle geochronologic period of the Cenozoic, starting with the Aquitanian age (at the transition from the Paleogene period) and ending with the Piacenzian age (at the transition to the Quaternary period). It is subdivided into two epochs (Miocene and Pliocene).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Neogene</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Neogen</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Néogène</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Neogene</skos:prefLabel>
	<skos:hiddenLabel>Jungtertiär</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pliocene"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Miocene"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Neogene"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pliocene"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Miocene"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Quaternary"/>
</rdf:Description>

<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Tertiary">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Tertiary</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Tertiär</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Tertiaire</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Terziario</skos:prefLabel>
	<skos:historyNote xml:lang="en">historical concept, no longer in use</skos:historyNote>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cenozoic"/>
	<skos:relatedMatch rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Paleogene"/>
	<skos:relatedMatch rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Neogene"/>
