<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Cretaceous">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Cretaceous (approx. from 145 to 66 Ma ago) is the youngest geochronologic period of the Mesozoic, starting with the Berriasian age (at the transition from the Jurassic period) and ending with the Maastrichtian age (at the transition to the Paleogene period). It is officially subdivided into two epochs (Early and Late Cretaceous).</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Cretaceous</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Kreide</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Crétacé</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Cretacico</skos:prefLabel>
	<skos:altLabel xml:lang="it">Cretaceo</skos:altLabel>
	<skos:hiddenLabel xml:lang="fr">Crétacique</skos:hiddenLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Mesozoic"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyCretaceous"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateCretaceous"/>
	<skos:narrower rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/MiddleCretaceous"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Cretaceous"/>
	<intervalFinishedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/LateCretaceous"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Jurassic"/>
	<intervalStartedBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyCretaceous"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/period"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
