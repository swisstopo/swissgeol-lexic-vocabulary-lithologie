<rdf:Description rdf:about="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Toarcian">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:definition xml:lang="en">The Toarcian (approx. from 184 to 174 Ma ago) is the youngest geochronologic age of the Early Jurassic. Its base, at the transition from the Pliensbachian, is placed at the first appearance of the ammonite genus Eodactylites, and the base of the Aalenian (first appearance of the ammonite genus Leioceras) defines its end.</skos:definition>
	<skos:inScheme rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy"/>
	<skos:prefLabel xml:lang="en">Toarcian</skos:prefLabel>
	<skos:prefLabel xml:lang="de">Toarcien</skos:prefLabel>
	<skos:prefLabel xml:lang="fr">Toarcien</skos:prefLabel>
	<skos:prefLabel xml:lang="it">Toarciano</skos:prefLabel>
	<skos:broader rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyJurassic"/>
	<skos:exactMatch rdf:resource="http://resource.geosciml.org/classifier/ics/ischart/Toarcian"/>
	<intervalMetBy xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Pliensbachian"/>
	<rank xmlns="http://resource.geosciml.org/ontology/timescale/gts#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/stage"/>
	<status xmlns="http://www.w3.org/ns/adms#" rdf:resource="https://dev-lexic.swissgeol.ch/active"/>
	<intervalMeets xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/Aalenian"/>
	<intervalFinishes xmlns="http://www.w3.org/2006/time#" rdf:resource="https://dev-lexic.swissgeol.ch/Chronostratigraphy/EarlyJurassic"/>
</rdf:Description>

